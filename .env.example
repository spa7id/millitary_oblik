# =============================================================================
# MILITARY OBLIK - ENVIRONMENT VARIABLES
# =============================================================================
# Цей файл містить приклади змінних оточення для проекту.
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO CORE SETTINGS
# -----------------------------------------------------------------------------

# SECRET_KEY - секретний ключ Django для криптографічних операцій
# Використовується для:
# - Підпису сесій та cookies
# - Генерації CSRF токенів
# - Криптографічних операцій
# ВАЖЛИВО: Згенеруйте унікальний ключ для production!
# Генерація: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION-use-random-50-chars-string

# DEBUG - режим налагодження
# True = режим розробки (показує детальні помилки, автоматично перезавантажується)
# False = режим production (приховує детальні помилки, вимагає ALLOWED_HOSTS)
# ВАЖЛИВО: ЗАВЖДИ встановлюйте False для production!
DEBUG=True

# ALLOWED_HOSTS - список дозволених хостів/доменів
# Розділяйте комами без пробілів
# Приклади:
# - Локальна розробка: localhost,127.0.0.1
# - Production: example.com,www.example.com
# - IP адреса: 192.168.1.100
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# DATABASE SETTINGS (POSTGRESQL)
# -----------------------------------------------------------------------------

# DATABASE_URL - URL з'єднання з PostgreSQL базою даних
# Формат: postgresql://username:password@host:port/database_name
#
# ПРИКЛАД ДЛЯ РОЗРОБКИ:
# DATABASE_URL=postgresql://military_user:your_password@localhost:5432/military_oblik_db
#
# Де:
#   military_user - ім'я користувача PostgreSQL
#   your_password - пароль користувача
#   localhost - хост (localhost для локальної БД)
#   5432 - порт PostgreSQL (за замовчуванням)
#   military_oblik_db - назва бази даних
#
# ВАЖЛИВО:
# - Створіть БД перед запуском: createdb military_oblik_db
# - Або створіть через psql: CREATE DATABASE military_oblik_db;
DATABASE_URL=postgresql://military_user:your_password@localhost:5432/military_oblik_db

# -----------------------------------------------------------------------------
# STATIC FILES SETTINGS
# -----------------------------------------------------------------------------

# STATIC_URL - URL шлях для статичних файлів (CSS, JS, зображення)
# За замовчуванням: /static/
STATIC_URL=/static/

# STATIC_ROOT - шлях до папки де collectstatic збирає всі статичні файли
# Використовується тільки для production
# Приклад: /var/www/military_oblik/staticfiles/
# STATIC_ROOT=/path/to/staticfiles/

# MEDIA_URL - URL шлях для медіа файлів (завантажені користувачем)
# За замовчуванням: /media/
MEDIA_URL=/media/

# MEDIA_ROOT - шлях до папки де зберігаються медіа файли
# Приклад: /var/www/military_oblik/media/
# MEDIA_ROOT=/path/to/media/

# -----------------------------------------------------------------------------